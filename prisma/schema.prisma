generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            String   @id
  name          String
  brand         String
  category      String
  subcategory   String
  price         Float
  originalPrice Float?
  stock         Int      @default(0)
  image         String
  labels        String[]
  sizes         String[]
  sizesStock    Json
  order         Int      @default(0)
  visible       Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model Order {
  id              String   @id
  date            DateTime @default(now())
  status          String
  customerName    String
  customerPhone   String
  customerEmail   String
  customerState   String
  customerCity    String
  customerAddress String
  customerZip     String
  carrier         String
  shippingCost    Float
  subtotal        Float
  total           Float
  items           Json
  paymentMethod   String
  receiptUrl      String?
  getnetPaymentId String?
  createdAt       DateTime @default(now())
}

model AdminUser {
  id       String @id
  username String @unique
  password String
}

model Config {
  key  String @id
  data Json
}
